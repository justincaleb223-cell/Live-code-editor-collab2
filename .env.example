# Server port
PORT=5000

# Frontend connects to this Socket.IO server URL
REACT_APP_BACKEND_URL=http://localhost:5000

# Comma-separated list of allowed origins for CORS and Socket.IO
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Request body size limit (express.json / urlencoded)
PAYLOAD_LIMIT=200kb

# Rate limiting (window in ms, max requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
